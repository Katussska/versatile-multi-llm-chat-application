        ]
      }
    },
    "/chats": {
      "post": {
        "operationId": "ChatController_createChat",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateChatDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Chat successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "User not authenticated"
          }
        },
        "summary": "Create a new chat",
        "tags": [
          "Chat"
        ]
      },
      "get": {
        "operationId": "ChatController_getUserChats",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of user chats sorted by creation date (newest first)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ChatResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          }
        },
        "summary": "Get all chats for the authenticated user",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{id}/messages": {
      "get": {
        "operationId": "ChatController_getChatMessages",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages sorted by creation date (oldest first)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Get all messages for a specific chat",
        "tags": [
          "Chat"
        ]
      },
      "post": {
        "operationId": "ChatController_addMessage",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMessageRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Add a message to a chat",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{id}": {
      "delete": {
        "operationId": "ChatController_deleteChat",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Delete a chat",
        "tags": [
          "Chat"
        ]
      },
      "patch": {
        "operationId": "ChatController_patchChat",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchChatDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Update chat title or favourite status",
        "tags": [
          "Chat"
        ]
      }
    },
    "/models": {
      "get": {
        "operationId": "ModelController_getModels",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of enabled models sorted by creation date",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ModelResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          }
        },
        "summary": "Get all available (enabled) models",
        "tags": [
          "Model"
        ]
      }
    },
    "/chats/{chatId}/messages/{messageId}": {
      "patch": {
        "operationId": "ChatController_patchMessage",
        "parameters": [
          {
            "name": "chatId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchMessageDto"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Message successfully updated"
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Message not found or access denied"
          }
        },
        "summary": "Update message content",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{id}/stream": {
      "post": {
        "operationId": "ChatController_streamMessage",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StreamMessageDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming LLM response"
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          },
          "429": {
            "description": "Monthly token limit exceeded"
          }
        },
        "summary": "Stream LLM response for a chat message",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{chatId}/messages/{messageId}/activate": {
      "patch": {
        "operationId": "ChatController_activateVersion",
        "parameters": [
          {
            "name": "chatId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "messageId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Version activated"
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Message not found or access denied"
          }
        },
        "summary": "Activate a specific message version",
        "tags": [
          "Chat"
        ]
      }
    }
  },
  "info": {
    "title": "Cognify API",
    "description": "Cognify backend API",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "ExampleGetResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Simple health-like status value."
          },
          "message": {
            "type": "string",
            "example": "Example GET endpoint is working.",
            "description": "Human-readable info message."
          }
        },
        "required": [
          "status",
          "message"
        ]
      },
      "ExampleRequestDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Ahoj Cognify",
            "description": "Text, ktery se ma vratit zpet v odpovedi."
          }
        },
        "required": [
          "message"
        ]
      },
      "ExampleResponseDto": {
        "type": "object",
        "properties": {
          "echoedMessage": {
            "type": "string",
            "example": "Ahoj Cognify",
            "description": "Stejna hodnota jako ve vstupnim DTO."
          },
          "length": {
            "type": "number",
            "example": 12,
            "description": "Delka textu ze vstupu."
          }
        },
        "required": [
          "echoedMessage",
          "length"
        ]
      },
      "GetAIMessageDTO": {
        "type": "object",
        "properties": {}
      },
      "CreateChatDto": {
        "type": "object",
        "properties": {
          "modelId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "default": "New Chat"
          }
        }
      },
      "ChatResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "modelId": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "favourite": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "title",
          "modelId",
          "createdAt",
          "updatedAt",
          "favourite"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "versionGroupId": {
            "type": "string",
            "nullable": true
          },
          "isActive": {
            "type": "boolean"
          },
          "versions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MessageVersionDto"
            }
          },
          "parentMessageId": {
            "type": "string",
            "nullable": true
          },
          "modelKey": {
            "type": "string",
            "nullable": true
          },
          "modelProvider": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "chatId",
          "content",
          "path",
          "createdAt",
          "updatedAt",
          "parentMessageId",
          "modelKey",
          "modelProvider",
          "versionGroupId",
          "isActive",
          "versions"
        ]
      },
      "CreateMessageRequestDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "content",
          "path"
        ]
      },
      "ModelResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "displayLabel": {
            "type": "string"
          },
          "iconKey": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "provider",
          "name",
          "displayLabel",
          "iconKey"
        ]
      },
      "PatchChatDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "favourite": {
            "type": "boolean"
          },
          "modelId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "PatchMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          }
        }
      },
      "StreamMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "parentMessageId": {
            "type": "string",
            "nullable": true
          },
          "regenerate": {
            "type": "boolean",
            "nullable": true
          },
          "truncateFromMessageId": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "content"
        ]
      },
      "MessageVersionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "modelProvider": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "content",
          "modelProvider",
          "createdAt"
        ]
      }
    }
  }
}