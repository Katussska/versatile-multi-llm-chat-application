                "schema": {
                  "$ref": "#/components/schemas/ExampleGetResponseDto"
                }
              }
            }
          }
        },
        "summary": "Example GET endpoint with DTO response",
        "tags": [
          "App"
        ]
      }
    },
    "/examples/echo": {
      "post": {
        "operationId": "AppController_createExample",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExampleRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Echoed payload for OpenAPI/Swagger demo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleResponseDto"
                }
              }
            }
          }
        },
        "summary": "Example POST endpoint with DTO request/response",
        "tags": [
          "App"
        ]
      }
    },
    "/gemini": {
      "post": {
        "operationId": "GeminiController_getResponse",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetAIMessageDTO"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
