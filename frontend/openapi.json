{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/examples/status": {
      "get": {
        "operationId": "AppController_getExampleStatus",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Simple status payload for OpenAPI/Swagger demo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleGetResponseDto"
                }
              }
            }
          }
        },
        "summary": "Example GET endpoint with DTO response",
        "tags": [
          "App"
        ]
      }
    },
    "/examples/echo": {
      "post": {
        "operationId": "AppController_createExample",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExampleRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Echoed payload for OpenAPI/Swagger demo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleResponseDto"
                }
              }
            }
          }
        },
        "summary": "Example POST endpoint with DTO request/response",
        "tags": [
          "App"
        ]
      }
    },
    "/gemini": {
      "post": {
        "operationId": "GeminiController_getResponse",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetAIMessageDTO"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Gemini"
        ]
      }
    },
    "/chats": {
      "post": {
        "operationId": "ChatController_createChat",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateChatDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Chat successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "User not authenticated"
          }
        },
        "summary": "Create a new chat",
        "tags": [
          "Chat"
        ]
      },
      "get": {
        "operationId": "ChatController_getUserChats",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of user chats sorted by creation date (newest first)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ChatResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          }
        },
        "summary": "Get all chats for the authenticated user",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{id}/messages": {
      "get": {
        "operationId": "ChatController_getChatMessages",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages sorted by creation date (oldest first)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Get all messages for a specific chat",
        "tags": [
          "Chat"
        ]
      },
      "post": {
        "operationId": "ChatController_addMessage",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMessageRequestDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Message successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Add a message to a chat",
        "tags": [
          "Chat"
        ]
      }
    },
    "/chats/{id}": {
      "delete": {
        "operationId": "ChatController_deleteChat",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "401": {
            "description": "User not authenticated"
          },
          "404": {
            "description": "Chat not found or access denied"
          }
        },
        "summary": "Delete a chat",
        "tags": [
          "Chat"
        ]
      }
    }
  },
  "info": {
    "title": "Cognify API",
    "description": "Cognify backend API",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "ExampleGetResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Simple health-like status value."
          },
          "message": {
            "type": "string",
            "example": "Example GET endpoint is working.",
            "description": "Human-readable info message."
          }
        },
        "required": [
          "status",
          "message"
        ]
      },
      "ExampleRequestDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Ahoj Cognify",
            "description": "Text, ktery se ma vratit zpet v odpovedi."
          }
        },
        "required": [
          "message"
        ]
      },
      "ExampleResponseDto": {
        "type": "object",
        "properties": {
          "echoedMessage": {
            "type": "string",
            "example": "Ahoj Cognify",
            "description": "Stejna hodnota jako ve vstupnim DTO."
          },
          "length": {
            "type": "number",
            "example": 12,
            "description": "Delka textu ze vstupu."
          }
        },
        "required": [
          "echoedMessage",
          "length"
        ]
      },
      "GetAIMessageDTO": {
        "type": "object",
        "properties": {}
      },
      "CreateChatDto": {
        "type": "object",
        "properties": {
          "modelId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "default": "New Chat"
          }
        }
      },
      "ChatResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "modelId": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "modelId",
          "createdAt",
          "updatedAt"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "chatId": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "favourite": {
            "type": "boolean"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "chatId",
          "content",
          "path",
          "favourite",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateMessageRequestDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "content",
          "path"
        ]
      }
    }
  }
}
